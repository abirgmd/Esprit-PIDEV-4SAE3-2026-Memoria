pipeline {
    agent any
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'fatma-dev',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git',
                    credentialsId: 'github-credentials'
            }
        }
        stage('2 - Pull Image') {
            steps {
                sh 'docker pull fatmaellouze03/memoria-planning:latest'
            }
        }
        stage('3 - Deploy Kubernetes') {
            steps {
                sh '''
                    echo "📦 Applying Kubernetes manifests in order..."
                    
                    # 1. Namespace
                    echo "1️⃣  Creating namespace..."
                    kubectl create namespace memoria --dry-run=client -o yaml | kubectl apply -f -
                    
                    # 2. PersistentVolumes
                    echo "2️⃣  Creating PersistentVolumes..."
                    kubectl apply -f MemoriA-dev/k8s/database/persistent-volume.yaml
                    
                    # 3. Secrets
                    echo "3️⃣  Applying Secrets..."
                    kubectl apply -f MemoriA-dev/k8s/database/mysql-secret.yaml
                    
                    # 4. ConfigMaps
                    echo "4️⃣  Applying ConfigMaps..."
                    kubectl apply -f MemoriA-dev/k8s/deployments/app-configmap.yaml
                    
                    # 5. MySQL (users_db for Planning)
                    echo "5️⃣  Deploying MySQL..."
                    kubectl apply -f MemoriA-dev/k8s/database/mysql-users-deployment.yaml
                    
                    # Wait for MySQL to be ready
                    echo "⏳ Waiting for MySQL to be ready..."
                    kubectl wait --for=condition=ready pod -l app=mysql-users -n memoria --timeout=120s || echo "⚠️ MySQL timeout"
                    
                    # 6. Planning Deployment & Service
                    echo "6️⃣  Deploying Planning Service..."
                    kubectl apply -f MemoriA-dev/k8s/deployments/planning-deployment.yaml
                    kubectl apply -f MemoriA-dev/k8s/services/planning-service.yaml
                    
                    echo "✅ All Kubernetes manifests applied"
                '''
            }
        }
        stage('4 - Vérifier Pod') {
            steps {
                sh 'kubectl rollout status deployment/memoria-planning -n memoria --timeout=120s'
            }
        }
        stage('5 - Smoke Test') {
            steps {
                sh 'kubectl get pods -n memoria'
                sh 'kubectl get services -n memoria'
            }
        }
    }
    post {
        success { echo 'Planning déployé sur Kubernetes ✅' }
        failure {
            sh 'kubectl get events -n memoria --sort-by=.metadata.creationTimestamp | tail -10'
        }
    }
}