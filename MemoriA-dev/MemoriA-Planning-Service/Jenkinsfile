pipeline {
    agent any
    environment {
        IMAGE_NAME = 'fatmaellouze03/memoria-planning'
        IMAGE_TAG = 'latest'
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'fatma-dev',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git',
                    credentialsId: 'github-credentials'
                echo "Code récupéré depuis GitHub"
            }
        }
        stage('0 - Locate POM') {
            steps {
                script {
                    env.SERVICE_DIR = sh(script: '''
                        if [ -f MemoriA-dev/MemoriA-Planning-Service/pom.xml ]; then
                          echo "MemoriA-dev/MemoriA-Planning-Service"
                        elif [ -f pom.xml ]; then
                          pwd
                        elif [ -f ../pom.xml ]; then
                          cd .. && pwd
                        else
                          find .. -path '*/MemoriA-Planning-Service/pom.xml' -print -quit | sed 's#/pom.xml##'
                        fi
                    ''', returnStdout: true).trim()
                    if (!env.SERVICE_DIR) {
                        error 'Impossible de trouver un pom.xml pour le service Planning'
                    }
                    env.POM_PATH = "${env.SERVICE_DIR}/pom.xml"
                    env.DOCKER_AVAILABLE = sh(script: 'command -v docker >/dev/null 2>&1 && echo true || echo false', returnStdout: true).trim()
                    echo "pom.xml trouvé : ${env.POM_PATH}"
                    echo "Docker disponible sur l'agent : ${env.DOCKER_AVAILABLE}"
                }
            }
        }
        stage('2 - Build Maven') {
            steps {
                sh "mvn -f ${env.POM_PATH} clean package -DskipTests"
            }
        }
        stage('3 - Tests') {
            steps {
                sh "mvn -f ${env.POM_PATH} test"
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${env.SERVICE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        stage('4 - Docker Build') {
            when {
                expression { env.DOCKER_AVAILABLE == 'true' }
            }
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }
        stage('5 - Docker Push') {
            when {
                expression { env.DOCKER_AVAILABLE == 'true' }
            }
            steps {
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }
    post {
        always {
            script {
                if (env.DOCKER_AVAILABLE == 'true') {
                    sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
                }
            }
        }
    }
}