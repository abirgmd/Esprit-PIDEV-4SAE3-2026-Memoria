pipeline {
    agent any
    environment {
        IMAGE_NAME = 'fatmaellouze03/memoria-planning'
        IMAGE_TAG = 'latest'
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'fatma-dev',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git',
                    credentialsId: 'github-credentials'
                echo "Code récupéré depuis GitHub"
            }
        }
        stage('2 - Build Maven') {
            steps {
                sh 'mvn -f MemoriA-dev/MemoriA-Planning-Service/pom.xml clean package -DskipTests'
            }
        }
        stage('3 - Tests') {
            steps {
                sh 'mvn -f MemoriA-dev/MemoriA-Planning-Service/pom.xml test'
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'MemoriA-dev/MemoriA-Planning-Service/target/surefire-reports/*.xml'
                }
            }
        }
        stage('4 - Docker Build') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} MemoriA-dev/MemoriA-Planning-Service/"
            }
        }
        stage('5 - Docker Push') {
            steps {
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }
    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}