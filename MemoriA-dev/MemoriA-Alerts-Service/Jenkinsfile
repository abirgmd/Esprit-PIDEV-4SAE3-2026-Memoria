pipeline {
    agent any
    environment {
        MS_NAME = 'MemoriA-Alerts-Service'
        IMAGE_NAME = 'fatmaellouze03/memoria-alerts'
        IMAGE_TAG = 'latest'
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'fatma-dev',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git',
                    credentialsId: 'github-credentials'
                echo "Code récupéré depuis GitHub — branche fatma-dev"
            }
        }
        stage('0 - Locate POM') {
            steps {
                script {
                    env.SERVICE_DIR = sh(script: '''
                        if [ -f pom.xml ]; then
                          pwd
                        elif [ -f ../pom.xml ]; then
                                                    cd .. && pwd
                        elif [ -f MemoriA-dev/MemoriA-Alerts-Service/pom.xml ]; then
                          echo "MemoriA-dev/MemoriA-Alerts-Service"
                        else
                          find .. -path '*/MemoriA-Alerts-Service/pom.xml' -print -quit | sed 's#/pom.xml##'
                        fi
                    ''', returnStdout: true).trim()
                    if (!env.SERVICE_DIR) {
                        error 'Impossible de trouver un pom.xml dans le workspace'
                    }
                    env.POM_PATH = "${env.SERVICE_DIR}/pom.xml"
                    echo "pom.xml trouvé : ${env.POM_PATH}"
                }
            }
        }
        stage('2 - Build Maven') {
            steps {
                sh "mvn -f ${env.POM_PATH} clean package -DskipTests"
                echo "Build Maven terminé : ${MS_NAME}"
            }
        }
        stage('3 — Tests') {
            steps {
                sh "mvn -f ${env.POM_PATH} test"
            }
            post {
                always {
                 // Publier les résultats de tests dans Jenkins
                junit testResults: "${env.SERVICE_DIR}/target/surefire-reports/*.xml", allowEmptyResults: true
                 }
                failure {
                    error 'Tests échoués — arrêt du pipeline'
                }
            }
        }
        stage('4 - Docker Build') {
            steps {
                dir("${env.SERVICE_DIR}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
                echo "Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
        stage('5 - Docker Push') {
            steps {
                sh "echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin"
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Image Docker poussée : ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }
    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}