pipeline {
    agent any
    
    environment {
        IMAGE_NAME = 'oussama433/memoria-frontend'
        IMAGE_TAG = 'latest'
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'devops-oussama',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
                echo "Code recupere depuis GitHub"
            }
        }
        
        stage('2 - Build Angular') {
            steps {
                dir('memoria-frontend') {
                    sh 'npm install'
                    sh 'npm run build --prod'
                    echo "Build Angular termine"
                }
            }
        }
        
        stage('3 - Build Docker Image') {
            steps {
                dir('memoria-frontend') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    echo "Image Docker construite"
                }
            }
        }
        
        stage('4 - Push Docker Hub') {
            steps {
                sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                echo "Image publiee sur Docker Hub"
            }
        }
    }
    
    post {
        success {
            echo "Pipeline CI reussi"
        }
        failure {
            echo "Pipeline CI echoue"
        }
    }
}
