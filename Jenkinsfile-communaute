pipeline {
    agent any
    environment {
        DOCKER_HUB_CRED_ID = 'docker-hub-credentials'
        DOCKER_HUB_USER    = 'abirgamoudi123'
        IMAGE_NAME         = 'memoria-backend-communaute'
        MS_NAME            = 'MemorIA_Backendgestioncommunaute'
        GIT_REPO_URL       = 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'main', url: "${GIT_REPO_URL}"
                echo "Code récupéré depuis GitHub - branche main"
            }
        }
        stage('2 - Build Maven') {
            steps {
                dir("${MS_NAME}") {
                    sh 'mvn clean package -DskipTests'
                }
                echo "Build Maven terminé : ${MS_NAME}"
            }
        }
        stage('3 - Tests') {
            steps {
                dir("${MS_NAME}") {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit "${MS_NAME}/target/surefire-reports/*.xml"
                }
                failure {
                    error 'Tests échoués - arrêt du pipeline'
                }
            }
        }
        stage('4 - Build Image Docker') {
            steps {
                dir("${MS_NAME}") {
                    sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ."
                }
                echo "Image Docker construite : ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
            }
        }
        stage('5 - Push Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_HUB_CRED_ID}", passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                        sh "echo \$PASS | docker login -u \$USER --password-stdin"
                        sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
                    }
                }
                echo "Image publiée sur Docker Hub : ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
            }
        }
        stage('6 - Keverntes') {
            steps {
                sh "sudo kubectl apply -f k8s/backend-communaute.yaml --kubeconfig=/home/vagrant/.kube/config"
                sh "sudo kubectl rollout status deployment/memoria-backend-communaute --kubeconfig=/home/vagrant/.kube/config"
            }
        }
    }
    post {
        success {
            echo "Pipeline CI réussi - image ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest disponible sur Docker Hub"
        }
        failure {
            echo "Pipeline CI échoué - vérifier les logs ci-dessus"
        }
        always {
            sh "docker rmi ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest || true"
        }
    }
}
