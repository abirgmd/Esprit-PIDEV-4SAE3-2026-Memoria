pipeline {
    agent any
    environment {
        DOCKER_HUB_USER = 'abirgamoudi123'
        IMAGE_NAME      = 'memoria-backend-communaute'
        MS_NAME         = 'MemorIA_Backendgestioncommunaute'
        KUBECONFIG_PATH = '/var/lib/jenkins/.kube/config'
    }
    stages {
        stage('1 - Build & Push Docker') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ./${MS_NAME}"
                    sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
                }
            }
        }
        stage('2 - Update Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/deployments/backend-communaute-deployment.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH} --validate=false"
                sh "kubectl apply -f k8s/services/backend-communaute-service.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH} --validate=false"
                sh "kubectl rollout status deployment/backend-communaute -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH} || true"
            }
        }
    }
}
