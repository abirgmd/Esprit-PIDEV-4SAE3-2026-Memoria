pipeline {
    agent any
    tools {
        maven 'MAVEN_HOME'
    }

    environment {
        DOCKER_HUB_CRED_ID = 'docker-hub-credentials'
        DOCKER_HUB_USER    = 'abirgamoudi123'
        IMAGE_NAME         = 'memoria-gateway'
        MS_NAME            = 'MemoriA-Gateway'
        GIT_REPO_URL       = 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
    }
    triggers {
        githubPush()
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'main-push', url: "${GIT_REPO_URL}"
                echo "Code récupéré depuis GitHub - branche main-push"
            }
        }
        stage('2 - Build Maven') {
            steps {
                dir("${MS_NAME}") {
                    sh 'mvn clean package -DskipTests'
                }
                echo "Build Maven terminé : ${MS_NAME}"
            }
        }
        stage('3 - Tests') {
            steps {
                script {
                    sh "docker run -d --name mysql-test-${IMAGE_NAME} -e MYSQL_ALLOW_EMPTY_PASSWORD=yes -e MYSQL_DATABASE=memoria_db -p 3306:3306 mysql:5.7 || true"
                    sh "sleep 15"
                    dir("${MS_NAME}") {
                        sh 'mvn test'
                    }
                }
            }
            post {
        stage('1 - Build & Push Docker') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ./MemoriA-Gateway"
                    sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
                }
            }
        }
        stage('2 - Update Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/deployments/gateway-deployment.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH} --validate=false"
                sh "kubectl apply -f k8s/services/gateway-service.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH} --validate=false"
                sh "kubectl rollout status deployment/memoria-gateway -n pidev --timeout=180s --kubeconfig=${KUBECONFIG_PATH} || true"
            }
        }
    }
    post {
        success {
            echo "Pipeline CI réussi - image ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest disponible sur Docker Hub"
        }
        failure {
            echo "Pipeline CI échoué - vérifier les logs ci-dessus"
        }
        always {
            sh "docker rmi ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest || true"
        }
    }
}
