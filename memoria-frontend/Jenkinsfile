// Jenkinsfile - Frontend Angular
pipeline {
    agent any
    
    environment {
        IMAGE_NAME = 'oussama433/memoria-frontend'
        IMAGE_TAG = 'latest'
        DOCKER_CREDS = credentials('docker-hub-credentials')
    }
    
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'devops-oussama',
                    url: 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
                echo "✅ Code récupéré depuis GitHub - branche devops-oussama"
            }
        }
        
        stage('2 - Build Angular') {
            steps {
                dir('memoria-frontend') {
                    sh '''
                        npm install
                        npm run build --prod
                    '''
                    echo "✅ Build Angular terminé"
                }
            }
        }
        
        stage('3 - Build Docker Image') {
            steps {
                dir('memoria-frontend') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                    echo "✅ Image Docker construite : ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }
        
        stage('4 - Push Docker Hub') {
            steps {
                sh """
                    echo ${DOCKER_CREDS_PSW} | docker login -u ${DOCKER_CREDS_USR} --password-stdin
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                """
                echo "✅ Image publiée sur Docker Hub : ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }
    }
    
    post {
        success {
            echo "🎉 Pipeline CI réussi - image ${IMAGE_NAME}:${IMAGE_TAG} disponible sur Docker Hub"
        }
        failure {
            echo "❌ Pipeline CI échoué - vérifier les logs ci-dessus"
        }
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}
