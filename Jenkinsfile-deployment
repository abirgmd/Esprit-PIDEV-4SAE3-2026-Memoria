pipeline {
    agent any
    environment {
        KUBECONFIG_PATH = '/var/lib/jenkins/.kube/config'
        GIT_REPO_URL    = 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
    }
    stages {
        stage('1 - Checkout Manifests K8s') {
            steps {
                git branch: 'main-push', url: "${GIT_REPO_URL}"
                echo 'Manifests Kubernetes rÃĐcupÃĐrÃĐs'
            }
        }
        stage('2 - DÃĐploiement Infrastructure (MySQL)') {
            steps {
                sh "sudo kubectl apply -f k8s/namespaces.yaml --kubeconfig=${KUBECONFIG_PATH} || true"
                sh "sudo kubectl apply -f k8s/secrets/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/deployments/mysql-pvc.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/deployments/mysql-deployment.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/services/mysql-service.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                
                echo 'Attente de dÃĐmarrage de MySQL...'
                sh "sudo kubectl rollout status deployment/mysql -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
            }
        }
        stage('3 - DÃĐploiement Eureka (Service Registry)') {
            steps {
                sh "sudo kubectl apply -f k8s/deployments/eureka-deployment.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/services/eureka-service.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                
                echo 'Attente de Eureka Server...'
                sh "sudo kubectl rollout status deployment/eureka-server -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
            }
        }
        stage('4 - DÃĐploiement des Microservices') {
            steps {
                sh "sudo kubectl apply -f k8s/deployments/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/services/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                
                echo 'VÃĐrification de la santÃĐ des microservices...'
                sh "sudo kubectl rollout status deployment/backend-activite -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/backend-communaute -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/memoria-gateway -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/frontend -n pidev --timeout=300s --kubeconfig=${KUBECONFIG_PATH}"
            }
        }
        stage('5 - Ãtat final') {
            steps {
                sh "sudo kubectl get pods -n pidev --kubeconfig=${KUBECONFIG_PATH}"
            }
        }
    }
    post {
        success {
            echo 'FÃĐlicitations ! DÃĐploiement complet et opÃĐrationnel.'
        }
        failure {
            echo 'Ãchec dÃĐtectÃĐ. VÃĐrification des logs...'
            sh "sudo kubectl get pods -n pidev --kubeconfig=${KUBECONFIG_PATH}"
        }
    }
}
