pipeline {
    agent any
    environment {
        DOCKER_REGISTRY = 'abirgamoudi123'
        GIT_REPO_URL    = 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
        KUBECONFIG_PATH = '/home/vagrant/.kube/config'
    }
    stages {
        stage('1 - Checkout Manifests K8s') {
            steps {
                git branch: 'main-push', url: "${GIT_REPO_URL}"
                echo 'Manifests Kubernetes récupérés'
            }
        }
        stage('2 - Déploiement Infrastructure (MySQL & Secrets)') {
            steps {
                sh "sudo kubectl apply -f k8s/namespaces.yaml --kubeconfig=${KUBECONFIG_PATH} || true"
                sh "sudo kubectl apply -f k8s/secrets/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/deployments/mysql-pvc.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/deployments/mysql-deployment.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/services/mysql-service.yaml -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                echo 'Infrastructure MySQL déployée'
            }
        }
        stage('3 - Déploiement des Services') {
            steps {
                sh "sudo kubectl apply -f k8s/deployments/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl apply -f k8s/services/ -n pidev --kubeconfig=${KUBECONFIG_PATH}"
                echo 'Tous les services appliqués sur le cluster K8s'
            }
        }
        stage('4 - Attendre que les Pods soient prets') {
            steps {
                sh "sudo kubectl rollout status deployment/eureka-server -n pidev --timeout=120s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/backend-activite -n pidev --timeout=120s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/backend-communaute -n pidev --timeout=120s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/memoria-gateway -n pidev --timeout=120s --kubeconfig=${KUBECONFIG_PATH}"
                sh "sudo kubectl rollout status deployment/frontend -n pidev --timeout=120s --kubeconfig=${KUBECONFIG_PATH}"
                echo 'Tous les déploiements sont opérationnels'
            }
        }
    }
    post {
        success {
            echo 'Déploiement complet réussi !'
        }
        always {
            sh "sudo kubectl get pods -n pidev --kubeconfig=${KUBECONFIG_PATH}"
        }
    }
}
