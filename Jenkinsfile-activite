pipeline {
    agent any
    tools {
        maven 'MAVEN_HOME'
    }
    environment {
        DOCKER_HUB_CRED_ID = 'docker-hub-credentials'
        DOCKER_HUB_USER    = 'abirgamoudi123'
        IMAGE_NAME         = 'memoria-backend-activite'
        MS_NAME            = 'MemorIA_Backendgestionactivitepublication'
        GIT_REPO_URL       = 'https://github.com/abirgmd/Esprit-PIDEV-4SAE3-2026-Memoria.git'
    }
    triggers {
        githubPush() // Déclenche le build à chaque push GitHub
    }
    stages {
        stage('1 - Checkout') {
            steps {
                git branch: 'main-push', url: "${GIT_REPO_URL}"
                echo "Code récupéré depuis GitHub - branche main-push"
            }
        }
        stage('2 - Build Maven') {
            steps {
                dir("${MS_NAME}") {
                    sh 'mvn clean package -DskipTests'
                }
                echo "Build Maven terminé : ${MS_NAME}"
            }
        }
        stage('3 - Tests') {
            steps {
                script {
                    // Lancer un MySQL temporaire pour les tests
                    sh "docker run -d --name mysql-test-${IMAGE_NAME} -e MYSQL_ALLOW_EMPTY_PASSWORD=yes -e MYSQL_DATABASE=Memoria_db -p 3306:3306 mysql:5.7 || true"
                    // Attendre que MySQL soit prêt
                    sh "sleep 15"
                    
                    dir("${MS_NAME}") {
                        sh 'mvn test' // On lance vraiment les tests cette fois
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${MS_NAME}/target/surefire-reports/*.xml"
                    // Supprimer le container de test
                    sh "docker rm -f mysql-test-${IMAGE_NAME} || true"
                }
                failure {
                    echo 'Tests échoués - vérifiez les rapports'
                }
            }
        }
        stage('4 - Build Image Docker') {
            steps {
                dir("${MS_NAME}") {
                    sh "docker build -t ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest ."
                }
                echo "Image Docker construite : ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
            }
        }
        stage('5 - Push Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_HUB_CRED_ID}", passwordVariable: 'PASS', usernameVariable: 'USER')]) {
                        sh "echo \$PASS | docker login -u \$USER --password-stdin"
                        sh "docker push ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
                    }
                }
                echo "Image publiée sur Docker Hub : ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest"
            }
        }
        stage('6 - Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/deployments/backend-activite-deployment.yaml -n pidev --kubeconfig=/var/lib/jenkins/.kube/config"
                sh "kubectl apply -f k8s/services/backend-activite-service.yaml -n pidev --kubeconfig=/var/lib/jenkins/.kube/config"
                sh "kubectl rollout status deployment/backend-activite -n pidev --kubeconfig=/var/lib/jenkins/.kube/config"
            }
        }
    }
    post {
        success {
            echo "Pipeline CI réussi - image ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest disponible sur Docker Hub"
        }
        failure {
            echo "Pipeline CI échoué - vérifier les logs ci-dessus"
        }
        always {
            sh "docker rmi ${DOCKER_HUB_USER}/${IMAGE_NAME}:latest || true"
        }
    }
}
